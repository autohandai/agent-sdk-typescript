# Autohand Code Agent SDK Configuration
# Copy this file to .env and fill in your values

# Provider selection: openrouter, ollama, openai, llamacpp, mlx, llmgateway, azure, zai
AUTOHAND_PROVIDER=openrouter

# API Key for selected provider
AUTOHAND_API_KEY=your-api-key-here

# Model name (provider-specific)
# OpenRouter: z-ai/glm-5.1, anthropic/claude-3-opus, etc.
# OpenAI: gpt-4, gpt-3.5-turbo, etc.
# Azure: gpt-4, etc. (deployment name)
# Ollama: llama2, llama3, etc.
# Z-AI: glm-5.1, etc.
# LLM Gateway: llama-3.1-8b, etc.
# Llama.cpp: llama-3-8b-instruct, etc.
# MLX: mlx-lm, etc.
AUTOHAND_MODEL=z-ai/glm-5.1

# Base URL (optional, provider-specific)
# OpenRouter: https://openrouter.ai/api/v1 (default)
# OpenAI: https://api.openai.com/v1 (default)
# Azure: https://your-resource.openai.azure.com (provider-specific)
# Ollama: http://localhost:11434 (default)
# Z-AI: https://api.z.ai/v1 (default)
# LLM Gateway: https://api.llmgateway.com/v1 (default)
# Llama.cpp: http://localhost:8080 (default)
# MLX: http://localhost:8080 (default)
AUTOHAND_BASE_URL=

# Provider-specific configurations
# Azure OpenAI
AUTOHAND_AZURE_RESOURCE_NAME=your-resource-name
AUTOHAND_AZURE_DEPLOYMENT_NAME=your-deployment-name

# Ollama
AUTOHAND_OLLAMA_BASE_URL=http://localhost:11434

# Llama.cpp
AUTOHAND_LLAMACPP_BASE_URL=http://localhost:8080

# MLX
AUTOHAND_MLX_BASE_URL=http://localhost:8080
